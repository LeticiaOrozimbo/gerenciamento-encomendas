            "pm.test('Status RECEBIDA', () => pm.expect(pm.response.json().status).to.eql('RECEBIDA'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenPorteiro}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"nomeMorador\": \"Ana Lima\",\n  \"apartamento\": \"303\",\n  \"descricao\": \"Vestido Zara - Caixa Rosa\"\n}" },
            "url": { "raw": "{{baseUrl}}/encomendas", "host": ["{{baseUrl}}"], "path": ["encomendas"] }
          }
        },
        {
          "name": "5.6 Ana Confirma Notificacao",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('notificacaoConfirmada = true', () => pm.expect(pm.response.json().notificacaoConfirmada).to.eql(true));"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenMorador}}" }],
            "url": { "raw": "{{baseUrl}}/encomendas/{{encomendaId}}/confirmar-notificacao", "host": ["{{baseUrl}}"], "path": ["encomendas", "{{encomendaId}}", "confirmar-notificacao"] }
          }
        },
        {
          "name": "5.7 Porteiro Da Baixa na Retirada",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Status RETIRADA', () => pm.expect(pm.response.json().status).to.eql('RETIRADA'));"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenPorteiro}}" }],
            "url": { "raw": "{{baseUrl}}/encomendas/{{encomendaId}}/retirar", "host": ["{{baseUrl}}"], "path": ["encomendas", "{{encomendaId}}", "retirar"] }
          }
        },
        {
          "name": "5.8 Verificar Estado Final",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Status final = RETIRADA', () => pm.expect(json.status).to.eql('RETIRADA'));",
            "pm.test('notificacaoConfirmada = true', () => pm.expect(json.notificacaoConfirmada).to.eql(true));",
            "pm.test('Apartamento = 303', () => pm.expect(json.apartamento).to.eql('303'));",
            "console.log('Fluxo completo validado!');"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenPorteiro}}" }],
            "url": { "raw": "{{baseUrl}}/encomendas/{{encomendaId}}", "host": ["{{baseUrl}}"], "path": ["encomendas", "{{encomendaId}}"] }
          }
        }
      ]
    }
  ]
}
