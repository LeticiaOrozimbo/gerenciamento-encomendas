          }
        },
        {
          "name": "1.4 Atualizar Morador (Bearer tokenMorador)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Telefone atualizado', () => pm.expect(pm.response.json().telefone).to.eql('11777770000'));"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenMorador}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Joao Silva Atualizado\",\n  \"telefone\": \"11777770000\",\n  \"apartamento\": \"101\"\n}" },
            "url": { "raw": "{{baseUrl}}/moradores/{{moradorId}}", "host": ["{{baseUrl}}"], "path": ["moradores", "{{moradorId}}"] }
          }
        },
        {
          "name": "1.5 Apartamento Inexistente (espera 400)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('Mensagem de erro', () => pm.expect(pm.response.json().erro).to.include('Morador nao encontrado'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenPorteiro}}" }],
            "url": { "raw": "{{baseUrl}}/moradores/apartamento/999", "host": ["{{baseUrl}}"], "path": ["moradores", "apartamento", "999"] }
          }
        },
        {
          "name": "1.6 Sem Token (espera 401)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('401 sem token', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/moradores", "host": ["{{baseUrl}}"], "path": ["moradores"] }
          }
        }
      ]
    },
