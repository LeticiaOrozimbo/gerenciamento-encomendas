{
  "info": {
    "name": "Gerenciamento de Encomendas v2",
    "description": "Collection completa JWT.\n\nIMPORTANTE: Execute pasta 0 (Setup) primeiro — os tokens sao salvos automaticamente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",           "value": "http://localhost:8080", "type": "string" },
    { "key": "tokenPorteiro",     "value": "", "type": "string" },
    { "key": "tokenMorador",      "value": "", "type": "string" },
    { "key": "moradorId",         "value": "", "type": "string" },
    { "key": "funcionarioId",     "value": "", "type": "string" },
    { "key": "encomendaId",       "value": "", "type": "string" },
    { "key": "tempFuncionarioId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "0. Setup - Cadastro e Login (execute primeiro)",
      "item": [
        {
          "name": "0.1 Cadastrar Porteiro (publico)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "var json = pm.response.json();",
            "pm.collectionVariables.set('funcionarioId', json.id);",
            "pm.test('Login salvo', () => pm.expect(json.login).to.eql('porteiro.joao'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Porteiro Joao\",\n  \"login\": \"porteiro.joao\",\n  \"senha\": \"senha123\"\n}" },
            "url": { "raw": "{{baseUrl}}/funcionarios", "host": ["{{baseUrl}}"], "path": ["funcionarios"] }
          }
        },
        {
          "name": "0.2 Login Porteiro - salva tokenPorteiro",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "var json = pm.response.json();",
            "pm.test('Token recebido', () => pm.expect(json.token).to.be.a('string').and.have.length.above(10));",
            "pm.collectionVariables.set('tokenPorteiro', json.token);",
            "console.log('tokenPorteiro salvo:', json.token.substring(0,30) + '...');"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"porteiro.joao\",\n  \"password\": \"senha123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "0.3 Cadastrar Morador com Login (publico)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "var json = pm.response.json();",
            "pm.collectionVariables.set('moradorId', json.id);",
            "pm.test('Apartamento 101', () => pm.expect(json.apartamento).to.eql('101'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Joao Silva\",\n  \"telefone\": \"11999990000\",\n  \"apartamento\": \"101\",\n  \"login\": \"joao.silva\",\n  \"senha\": \"morador123\"\n}" },
            "url": { "raw": "{{baseUrl}}/moradores", "host": ["{{baseUrl}}"], "path": ["moradores"] }
          }
        },
        {
          "name": "0.4 Login Morador - salva tokenMorador",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "var json = pm.response.json();",
            "pm.test('Token recebido', () => pm.expect(json.token).to.be.a('string').and.have.length.above(10));",
            "pm.collectionVariables.set('tokenMorador', json.token);",
            "console.log('tokenMorador salvo:', json.token.substring(0,30) + '...');"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"joao.silva\",\n  \"password\": \"morador123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "0.5 Login Invalido (espera 401)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));",
            "pm.test('Mensagem de erro', () => pm.expect(pm.response.json().erro).to.include('nvalidas'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"nao.existe\",\n  \"password\": \"senhaerrada\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
